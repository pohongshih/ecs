rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isTeacher() {
      return isSignedIn() && getUserData().role == 'teacher';
    }

    function isStudent() {
      return isSignedIn() && getUserData().role == 'student';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.uid == request.auth.uid &&
             data.email == request.auth.token.email &&
             data.role in ['teacher', 'student'] &&
             data.createdAt == request.time;
    }

    function isValidClass(data) {
      return data.keys().hasAll(['name', 'teacherId', 'description', 'studentEmails', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.name is string && data.name.size() <= 100 &&
             data.teacherId == request.auth.uid &&
             data.studentEmails is list &&
             data.createdAt == request.time;
    }

    function isValidHomework(data) {
      return data.keys().hasAll(['classId', 'title', 'instructions', 'dueDate', 'teacherId', 'createdAt']) &&
             data.keys().size() == 6 &&
             data.title is string && data.title.size() <= 200 &&
             data.teacherId == request.auth.uid &&
             data.createdAt == request.time;
    }

    function isValidSubmission(data) {
      return data.keys().hasAll(['homeworkId', 'studentId', 'audioUrl', 'status', 'createdAt']) &&
             data.homeworkId is string &&
             data.studentId == request.auth.uid &&
             data.audioUrl is string &&
             data.status == 'submitted' &&
             data.createdAt == request.time;
    }

    // --- Routes ---

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isTeacher());
      allow list: if isTeacher(); // Teachers can browse students (simplified)
      allow create: if isSignedIn() && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['name', 'classIds']) &&
                       incoming().role == existing().role;
    }

    match /classes/{classId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); // Filtered by client, but protected by content in real app
      allow create: if isTeacher() && isValidClass(incoming());
      allow update: if isTeacher() && existing().teacherId == request.auth.uid && 
                       isValidClass(incoming()) &&
                       incoming().diff(existing()).affectedKeys().hasAll(['name', 'description', 'studentEmails']);
      allow delete: if isTeacher() && existing().teacherId == request.auth.uid;
    }

    match /homeworks/{homeworkId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isTeacher() && isValidHomework(incoming());
      allow update: if isTeacher() && existing().teacherId == request.auth.uid && isValidHomework(incoming());
      allow delete: if isTeacher() && existing().teacherId == request.auth.uid;
    }

    match /submissions/{submissionId} {
      allow get: if isSignedIn() && (existing().studentId == request.auth.uid || isTeacher());
      allow list: if isSignedIn() && (resource.data.studentId == request.auth.uid || isTeacher());
      
      allow create: if isStudent() && isEmailVerified() && isValidSubmission(incoming()) &&
                       exists(/databases/$(database)/documents/homeworks/$(incoming().homeworkId));
      
      allow update: if isSignedIn() && (
        // Action: Teacher Grades
        (isTeacher() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'score', 'feedback', 'aiFeedback', 'teacherComment', 'updatedAt']) &&
         incoming().updatedAt == request.time && incoming().status == 'graded') ||
        // Action: Student re-uploads (if not graded)
        (isStudent() && existing().studentId == request.auth.uid && existing().status == 'submitted' &&
         incoming().diff(existing()).affectedKeys().hasOnly(['audioUrl', 'updatedAt']) &&
         incoming().updatedAt == request.time)
      );
    }
  }
}
