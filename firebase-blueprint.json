{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User information and roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["teacher", "student"] },
        "classIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Class": {
      "title": "Classroom",
      "description": "A group of students managed by a teacher",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "teacherId": { "type": "string" },
        "description": { "type": "string" },
        "studentEmails": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "teacherId"]
    },
    "Homework": {
      "title": "Assignment",
      "description": "Homework created by a teacher for a class",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "classId": { "type": "string" },
        "title": { "type": "string" },
        "instructions": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "teacherId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["classId", "title", "teacherId"]
    },
    "Submission": {
      "title": "Student Submission",
      "description": "Audio recording and feedback for homework",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "homeworkId": { "type": "string" },
        "studentId": { "type": "string" },
        "audioUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["submitted", "graded"] },
        "score": { "type": "number" },
        "feedback": { "type": "string" },
        "aiFeedback": { "type": "string" },
        "teacherComment": { "type": "string" },
        "transcript": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["homeworkId", "studentId", "audioUrl", "status"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Individual user profiles"
    },
    "classes/{classId}": {
      "schema": "Class",
      "description": "Class information"
    },
    "homeworks/{homeworkId}": {
      "schema": "Homework",
      "description": "Homework assignments"
    },
    "submissions/{submissionId}": {
      "schema": "Submission",
      "description": "Homework submissions and grading"
    }
  }
}
